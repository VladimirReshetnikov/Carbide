# SPDX-License-Identifier: Apache-2.0

# Normalize line endings to LF in repository and checkout
* text=auto eol=lf

# Treat certain files as binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.bmp binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.7z binary

# Preserve vendored upstream license and notice files byte-for-byte. Their original
# line endings and intentional trailing space are exempt from repository whitespace checks.
**/third-party/** -text whitespace=-blank-at-eol,-blank-at-eof
