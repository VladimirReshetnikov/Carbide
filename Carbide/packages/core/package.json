{
  "name": "@carbide/core",
  "version": "0.1.0-dev",
  "description": "C# compile-and-run framework for browser and Node.js, powered by Roslyn on Mono-WASM.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    },
    "./interop/schema": {
      "types": "./dist/interop/schema.d.ts",
      "default": "./dist/interop/schema.js"
    }
  },
  "files": [
    "dist",
    "src/bin/Release/net10.0/publish/wwwroot/_framework",
    "ATTRIBUTION.md",
    "THIRD_PARTY_NOTICES.md",
    "third-party/**/*"
  ],
  "scripts": {
    "build:dotnet": "dotnet publish -c Release src/Carbide.Core.csproj",
    "build:ts": "tsc -p tsconfig.json",
    "build:test-fixtures": "node test/fixtures/helper-dll/build.mjs",
    "build": "npm run build:dotnet && npm run build:ts && npm run build:test-fixtures",
    "test": "node --test --test-force-exit --test-concurrency=2 test/smoke.node.test.mjs test/node/*.test.mjs",
    "test:fast": "node --test --test-force-exit --test-concurrency=2 test/smoke.node.test.mjs test/node/hello.test.mjs test/node/build-emit.test.mjs test/node/top-level-vs-main.test.mjs test/node/asset-server.test.mjs test/node/json-schema.test.mjs test/node/syntax-error.test.mjs test/node/runtime-error.test.mjs",
    "test:smoke": "node --test --test-force-exit test/smoke.node.test.mjs",
    "test:node": "node --test --test-force-exit --test-concurrency=2 test/node/*.test.mjs",
    "test:browser": "playwright test",
    "test:browser:fast": "playwright test hello interactive-hello interactive-readline interactive-beep interactive-dispose-midrun",
    "pack:core": "npm pack"
  },
  "keywords": [
    "wasm",
    "webassembly",
    "carbide",
    "csharp",
    "dotnet",
    "compiler",
    "roslyn"
  ],
  "license": "Apache-2.0",
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/node": "^22.9.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VladimirReshetnikov/Carbide.git",
    "directory": "Carbide/packages/core"
  }
}
