<Project Sdk="Microsoft.NET.Sdk.WebAssembly">
  <PropertyGroup>
    <TargetFramework>$(NetVersion)</TargetFramework>
    <RuntimeIdentifier>browser-wasm</RuntimeIdentifier>
    <OutputType>Exe</OutputType>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>

    <!-- M1: disable publish trimming. Trimmed runtime assemblies used as metadata references
         drop BCL methods (e.g. Console.Write) that the user's compilation expects, yielding
         CS0117. M3 restores trimming once @carbide/refs-net10.0 ships untrimmed reference
         assemblies (architecture Q.3). -->
    <IsTrimmable>false</IsTrimmable>
    <PublishTrimmed>false</PublishTrimmed>

    <EnableTrimAnalyzer>false</EnableTrimAnalyzer>
    <SuppressTrimAnalysisWarnings>true</SuppressTrimAnalysisWarnings>

    <WasmFingerprintAssets>false</WasmFingerprintAssets>
    <CompressionEnabled>false</CompressionEnabled>
    <!-- WasmBundlerFriendlyBootConfig inlines asset imports into dotnet.js; leaving it off
         lets Node/non-bundler callers fetch _framework/*.dll over http without a patch step. -->
    <WasmBundlerFriendlyBootConfig>false</WasmBundlerFriendlyBootConfig>

    <WasmEnableWebcil>false</WasmEnableWebcil>

    <RootNamespace>Carbide.Core</RootNamespace>
    <AssemblyName>Carbide.Core</AssemblyName>
  </PropertyGroup>

  <PropertyGroup Condition="$(Configuration) == 'Release'">
    <DebuggerSupport>false</DebuggerSupport>
    <UseNativeHttpHandler>true</UseNativeHttpHandler>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Jab" Version="0.11.0" PrivateAssets="all" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.14.0" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Features" Version="4.14.0" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.0-preview.5.25277.114" />
  </ItemGroup>

  <PropertyGroup Condition="$(Configuration) == 'Debug'">
    <WasmNativeStrip>false</WasmNativeStrip>
    <WasmEmitSymbolMap>true</WasmEmitSymbolMap>
    <WasmBuildNative>true</WasmBuildNative>
    <WasmDebugLevel>1</WasmDebugLevel>
    <WasmNativeDebugSymbols>true</WasmNativeDebugSymbols>
  </PropertyGroup>

  <ItemGroup Condition="'$(PublishTrimmed)' == 'True'">
    <TrimmerRootDescriptor Include="roots.xml" />
  </ItemGroup>

  <!-- Directory.Build.props enables IsTrimmable by default; override locally to match the
       settings above. -->
  <PropertyGroup>
    <IsTrimmable>false</IsTrimmable>
    <PublishTrimmed>false</PublishTrimmed>
    <EnableTrimAnalyzer>false</EnableTrimAnalyzer>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="node_modules/**/*" />
    <None Remove="dist/**/*" />
  </ItemGroup>

  <!--
    T3 — overlay Carbide's forked System.Console.dll on top of the stock one that the
    Mono-WASM publish pipeline drops into `_framework/`. Runs after Publish so the file we
    copy into survives; the loader picks up the fork (same assembly name, same TFM) at
    `dotnet.js` boot time because the loader trusts the file by name.

    We don't ProjectReference the fork — that would double-register the assembly in the
    Core build graph and confuse ref-pack resolution. Instead we build the fork
    out-of-band here and file-copy its output.
  -->
  <Target Name="CarbideBuildForkedSystemConsole" BeforeTargets="Publish">
    <!--
      Restore explicitly: a project driven through an MSBuild task call is not part of the
      entry project's implicit-restore graph, so a fresh clone would fail with NETSDK1004.
      Restore and Build must be separate task calls with different global-property sets —
      a combined Restore;Build reuses the pre-restore evaluation and cannot see the
      obj/*.props|targets that restore generates.
    -->
    <MSBuild Projects="..\..\core-bcl\System.Console\Carbide.System.Console.csproj"
             Properties="Configuration=$(Configuration)"
             Targets="Restore" />
    <MSBuild Projects="..\..\core-bcl\System.Console\Carbide.System.Console.csproj"
             Properties="Configuration=$(Configuration);CarbideExplicitlyRestored=true"
             Targets="Build" />
  </Target>
  <Target Name="CarbideOverlayForkedSystemConsole" AfterTargets="Publish">
    <PropertyGroup>
      <CarbideForkedConsoleDll>..\..\core-bcl\System.Console\bin\$(Configuration)\$(TargetFramework)\System.Console.dll</CarbideForkedConsoleDll>
      <CarbideFrameworkPublishDir>$(PublishDir)wwwroot\_framework\</CarbideFrameworkPublishDir>
    </PropertyGroup>
    <Error Condition="!Exists('$(CarbideForkedConsoleDll)')"
           Text="T3 overlay failed: forked System.Console.dll not found at $(CarbideForkedConsoleDll). Build Carbide.System.Console.csproj first." />
    <Error Condition="!Exists('$(CarbideFrameworkPublishDir)System.Console.dll')"
           Text="T3 overlay failed: stock System.Console.dll not found at $(CarbideFrameworkPublishDir). Did the Mono-WASM publish step run?" />
    <Copy SourceFiles="$(CarbideForkedConsoleDll)"
          DestinationFolder="$(CarbideFrameworkPublishDir)"
          OverwriteReadOnlyFiles="true"
          UseHardlinksIfPossible="false" />
    <Message Text="T3: overlaid forked System.Console.dll into $(CarbideFrameworkPublishDir)" Importance="high" />
  </Target>
</Project>
