{
  "name": "@carbide/cli",
  "version": "0.0.0",
  "description": "Command-line interface for Carbide: build / run / validate C# projects without a .NET SDK install.",
  "type": "module",
  "main": "./dist/bin/carbide.js",
  "bin": {
    "carbide": "./dist/bin/carbide.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:ts": "tsc -p tsconfig.json",
    "build": "npm run build:ts",
    "test": "node --test --test-force-exit --test-concurrency=1 test/*.test.mjs",
    "test:live": "node --test --test-force-exit --test-concurrency=1 test/integration/*.test.mjs"
  },
  "keywords": [
    "carbide",
    "csharp",
    "dotnet",
    "cli",
    "compiler"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@carbide/core": "file:../core",
    "@carbide/msbuild-lite": "file:../msbuild-lite",
    "@carbide/nuget": "file:../nuget"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^22.9.0"
  }
}
