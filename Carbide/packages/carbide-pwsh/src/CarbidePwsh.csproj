<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>$(NetVersion)</TargetFramework>
    <OutputType>Exe</OutputType>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>CarbidePwsh</RootNamespace>
    <AssemblyName>CarbidePwsh</AssemblyName>
    <LangVersion>preview</LangVersion>
    <!-- Style and micro-optimization analyzers are noisy for a hand-rolled interpreter; the
         interesting quality signal is the Roslyn diagnostics and our xUnit tests. -->
    <NoWarn>$(NoWarn);IDE0008;IDE0028;IDE0046;IDE0055;IDE0051;IDE0058;IDE0059;IDE0290;IDE0300;IDE0301;CA1031;CA1062;CA1724;CA1822;CA1859;CA1063</NoWarn>
    <AnalysisLevel>latest-recommended</AnalysisLevel>
    <EnforceCodeStyleInBuild>false</EnforceCodeStyleInBuild>
  </PropertyGroup>

  <!-- Phase 1 uses reflection against curated BCL types; trimming strips members we
       dispatch at runtime. Override the repository-wide trimming defaults from
       Carbide/Directory.Build.props. Trim-safety is a Phase-4 concern. -->
  <PropertyGroup>
    <IsTrimmable>false</IsTrimmable>
    <PublishTrimmed>false</PublishTrimmed>
    <EnableTrimAnalyzer>false</EnableTrimAnalyzer>
    <SuppressTrimAnalysisWarnings>true</SuppressTrimAnalysisWarnings>
    <TrimmerSingleWarn>true</TrimmerSingleWarn>
    <DefineConstants>$(DefineConstants);CARBIDE_PWSH_EMBEDDED_MULTISHELL</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\carbide-shell-core\src\CarbideShellCore.csproj" />
    <ProjectReference Include="..\..\carbide-cmd\src\CarbideCmd.csproj" />
    <ProjectReference Include="..\..\carbide-bash\src\CarbideBash.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\..\carbide-multishell\src\MultishellSession.cs" Link="Shared\MultishellSession.cs" />
    <Compile Include="..\..\carbide-multishell\src\VirtualExecutableCatalog.cs" Link="Shared\VirtualExecutableCatalog.cs" />
    <Compile Include="..\..\carbide-multishell\src\MultishellVirtualExecutableHandler.Core.cs" Link="Shared\MultishellVirtualExecutableHandler.Core.cs" />
    <Compile Include="..\..\carbide-multishell\src\MultishellVirtualExecutableHandler.Basic.cs" Link="Shared\MultishellVirtualExecutableHandler.Basic.cs" />
    <Compile Include="..\..\carbide-multishell\src\MultishellVirtualExecutableHandler.Advanced.cs" Link="Shared\MultishellVirtualExecutableHandler.Advanced.cs" />
    <Compile Include="..\..\carbide-multishell\src\MultishellVirtualExecutableHandler.Python.cs" Link="Shared\MultishellVirtualExecutableHandler.Python.cs" />
    <Compile Include="..\..\carbide-multishell\src\MultishellVirtualExecutableHandler.Perl.cs" Link="Shared\MultishellVirtualExecutableHandler.Perl.cs" />
    <Compile Include="..\..\carbide-multishell\src\MultishellVirtualExecutableHandler.CScript.cs" Link="Shared\MultishellVirtualExecutableHandler.CScript.cs" />
    <Compile Include="..\..\carbide-multishell\src\MultishellVirtualExecutableHandler.Dotnet.cs" Link="Shared\MultishellVirtualExecutableHandler.Dotnet.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="SharpCompress" Version="0.39.0" />
  </ItemGroup>
</Project>
