{
  "name": "@carbide/carbide-pwsh",
  "version": "0.1.0",
  "private": true,
  "description": "The public Carbide shell endpoint: a pwsh-first shared session with nested cmd/bash and one virtual executable catalog.",
  "type": "module",
  "scripts": {
    "serve": "node scripts/serve.mjs",
    "smoke": "node scripts/smoke.mjs",
    "test:browser": "node --test --test-force-exit test/browser/*.test.mjs",
    "test:browser:dotnet": "node --test --test-force-exit test/browser/dotnet-interactive.test.mjs"
  },
  "keywords": [
    "carbide",
    "wasm",
    "mono-wasm",
    "powershell",
    "pwsh",
    "cmd",
    "bash",
    "shell",
    "multishell",
    "repl",
    "xterm"
  ]
}
