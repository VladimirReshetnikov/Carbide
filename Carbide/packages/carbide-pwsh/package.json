{
  "name": "@carbide/carbide-pwsh",
  "version": "0.1.0",
  "private": true,
  "description": "The public Carbide shell endpoint: a pwsh-first shared session with nested cmd/bash and one virtual executable catalog.",
  "type": "module",
  "license": "Apache-2.0",
  "files": [
    "index.html",
    "scripts/*.mjs",
    "src/*.csproj",
    "src/*.cs",
    "src/Cmdlets/**/*.cs",
    "src/Errors/*.cs",
    "src/Host/*.cs",
    "src/Lexer/*.cs",
    "src/Parser/**/*.cs",
    "src/Runtime/*.cs",
    "parity/*.csproj",
    "parity/*.cs",
    "parity/*.ps1",
    "parity/*.json",
    "parity/*.md",
    "test/*.csproj",
    "test/*.cs",
    "test/browser/*.mjs"
  ],
  "scripts": {
    "serve": "node scripts/serve.mjs",
    "smoke": "node scripts/smoke.mjs",
    "test:browser": "node --test --test-force-exit --test-concurrency=1 test/browser/*.test.mjs",
    "test:browser:dotnet": "node --test --test-force-exit --test-concurrency=1 test/browser/dotnet-*.test.mjs",
    "test:browser:dotnet-nested": "node --test --test-force-exit --test-concurrency=1 test/browser/dotnet-nested-shells.test.mjs"
  },
  "keywords": [
    "carbide",
    "wasm",
    "mono-wasm",
    "powershell",
    "pwsh",
    "cmd",
    "bash",
    "shell",
    "multishell",
    "repl",
    "xterm"
  ]
}
